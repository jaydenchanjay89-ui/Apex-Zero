const { Client, GatewayIntentBits, EmbedBuilder, ActionRowBuilder, ButtonBuilder, ButtonStyle } = require('discord.js');

const client = new Client({ intents: [GatewayIntentBits.Guilds, GatewayIntentBits.GuildMessages] });

client.on('interactionCreate', async interaction => {
    if (!interaction.isCommand()) return;

    if (interaction.commandName === 'raid') {
        const raidEmbed = new EmbedBuilder()
            .setColor('#FF3E3E') 
            .setTitle('🚨 Live Teamers Alert')
            .setDescription(`${interaction.user} 需要即時支援！`)
            .addFields(
                { name: 'Started', value: 'a minute ago', inline: true },
                { name: 'Status', value: '`Live`', inline: true },
                { name: 'Region / Server', value: '`Singapore`', inline: true },
                { name: 'Reason', value: 'i saw 2 guys doing team blackflash' }
            )
            .setThumbnail('https://roblox-avatar-url.com/image.png') 
            .setFooter({ text: `Requested by ${interaction.user.tag}` });
        const buttons = new ActionRowBuilder()
            .addComponents(
                new ButtonBuilder()
                    .setCustomId('join_raid')
                    .setLabel('Help')
                    .setStyle(ButtonStyle.Success), 
                new ButtonBuilder()
                    .setCustomId('end_raid')
                    .setLabel('End')
                    .setStyle(ButtonStyle.Secondary) 
            );

        await interaction.reply({ embeds: [raidEmbed], components: [buttons] });
    }
});

